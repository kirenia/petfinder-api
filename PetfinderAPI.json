                  "pm.test(\"Response reports success\", function () {",
                  "    const responseBody = pm.response.json();",
                  "    pm.expect(responseBody.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test(\"Each pet has a non-empty name and a populated shelter\", function () {",
                  "    const responseBody = pm.response.json();",
                  "    const pets = responseBody.data;",
                  "    pm.expect(pets).to.be.an('array');",
                  "",
                  "    pets.forEach((pet) => {",
                  "        pm.expect(pet.name).to.be.a('string').and.to.not.be.empty;",
                  "        pm.expect(pet.shelter).to.have.property('name');",
                  "    });",
                  "});"
